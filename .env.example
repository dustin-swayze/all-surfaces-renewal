# Copy this file to .env and fill in real values.
# Anything prefixed with VITE_ is exposed to the browser at build time.

# Site identity
VITE_SITE_NAME="All Surfaces Renewal and Repair"

# Contact info shown in the footer and on the contact page
VITE_CONTACT_PHONE=""
VITE_CONTACT_EMAIL=""
VITE_FACEBOOK_URL=""
VITE_SERVICE_AREA=""

# Formspree endpoint for the quote form.
# Create one at https://formspree.io (free tier is plenty for a small business).
# Paste the full URL, e.g. https://formspree.io/f/abcd1234
# Formspree handles spam filtering (honeypot + Akismet) and emails submissions
# directly to the address on the form's settings page.
VITE_FORMSPREE_ENDPOINT=""
