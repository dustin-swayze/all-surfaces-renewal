# Copy this file to .env and fill in real values.
# Anything prefixed with VITE_ is exposed to the browser at build time.

# Site identity
VITE_SITE_NAME="All Surfaces Renewal and Repair"

# Contact info shown in the footer and on the contact page
VITE_CONTACT_PHONE=""
VITE_CONTACT_EMAIL=""
VITE_FACEBOOK_URL="https://www.facebook.com/allsurfacefix"
VITE_SERVICE_AREA=""

# Business hours as a single display string. Free-text so it can format
# naturally. Example: "Mon–Fri, 8 AM – 5 PM" or "By appointment".
VITE_BUSINESS_HOURS=""

# Optional logo image. Leave blank to use the text-only brand mark.
# When set, should be a path to a file under /public (served from the root).
# Example: VITE_LOGO_URL="/images/logo.svg"
VITE_LOGO_URL=""

# Formspree endpoint for quote form email notifications (server-side only).
# Used by the /api/submit-quote Vercel function — NOT exposed to the browser.
# Create a form at https://formspree.io and paste the full URL here.
FORMSPREE_ENDPOINT=""

# API key for the portfolio lead ingest endpoint (server-side only).
# Must match INGEST_API_KEY in the portfolio project (dswayze.dev).
# Used by /api/submit-quote to save leads to the dashboard.
INGEST_API_KEY=""
